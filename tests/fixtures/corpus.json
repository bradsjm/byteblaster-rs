{
  "version": 1,
  "cases": [
    {
      "id": "sync_recovery_with_garbage",
      "description": "Leading garbage bytes followed by a valid frame should resync and emit data.",
      "payload_encoding": "base64-xor-wire",
      "expected": {
        "result": "success",
        "must_emit": ["DataBlock"]
      }
    },
    {
      "id": "malformed_header_rejected",
      "description": "Data block with invalid 80-byte header should fail with InvalidHeader.",
      "payload_encoding": "base64-xor-wire",
      "expected": {
        "result": "error",
        "error": "InvalidHeader"
      }
    },
    {
      "id": "server_list_full_format",
      "description": "Full server list update should populate regular and sat server lists.",
      "payload_encoding": "base64-xor-wire",
      "expected": {
        "result": "success",
        "must_emit": ["ServerListUpdate"]
      }
    }
  ]
}
