# Required for live ingest. Use your EMWIN account email.
EMWIN_USERNAME=you@example.com

# Optional. Set both for Weather Wire instead of QBT.
# EMWIN_RECEIVER=wxwire
# EMWIN_PASSWORD=your-password

# Optional upstream overrides.
# EMWIN_SERVER=203.0.113.10:2210,203.0.113.11:2210
# EMWIN_SERVER_LIST_PATH=/run/emwin/server-list.json

# Optional server tuning.
EMWIN_CORS_ORIGIN=*
RUST_LOG=info

# Optional compose overrides.
# EMWIN_HTTP_PORT=8080
# POSTGRES_PORT=5432
# MINIO_PORT=9000
# MINIO_CONSOLE_PORT=9001
# POSTGRES_DB=emwin
# POSTGRES_USER=emwin
# POSTGRES_PASSWORD=emwin
# MINIO_ROOT_USER=emwinminio
# MINIO_ROOT_PASSWORD=emwinminiosecret
# MINIO_BUCKET=emwin
# EMWIN_OUTPUT_DIR=s3://emwin/emwin
# EMWIN_PERSIST_DATABASE_URL=postgresql://emwin:emwin@postgres:5432/emwin?sslmode=disable

# Optional S3-compatible storage settings when EMWIN_OUTPUT_DIR uses s3://...
# AWS_ENDPOINT_URL=http://minio:9000
# AWS_REGION=us-east-1
# AWS_DEFAULT_REGION=us-east-1
# AWS_ACCESS_KEY_ID=emwinminio
# AWS_SECRET_ACCESS_KEY=emwinminiosecret
# AWS_SESSION_TOKEN=your-session-token
# AWS_PROFILE=your-profile
